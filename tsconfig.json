{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "rootDir": "./src",
    "outDir": "./scripts",
    "removeComments": false,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"]
}