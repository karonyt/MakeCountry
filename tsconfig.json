{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "rootDir": "./src",
    "outDir": "./script",
    "removeComments": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}